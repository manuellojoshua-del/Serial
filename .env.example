BOT_TOKEN=123456789:YOUR_TELEGRAM_BOT_TOKEN
CHANNEL_ID=-1001234567890
SECRET_KEY=ganti-dengan-kunci-panel-yang-panjang
TMDB_API_KEY=your_tmdb_api_key

# Local Telegram Bot API service di Railway
TELEGRAM_API_BASE=http://telegram-bot-api.railway.internal:8081

# Tidak memerlukan GOOGLE_SERVICE_ACCOUNT_JSON atau Google Drive API key.
# Folder video + subtitle harus: Anyone with the link - Viewer.

TMDB_LANGUAGE=id-ID
MAX_QUEUE=20
FFMPEG_PRESET=veryfast
FFMPEG_CRF=23
DEFAULT_THREAD_ID=0
TOPIC_OPTIONS=General:0
TOPIC_STORE_PATH=/data/telegram-topics.json
SERIES_STORE_PATH=/data/telegram-series.json
EPISODE_BUTTONS_PER_ROW=5

# Penyimpanan permanen Railway Volume
# Jika /data tersedia, v10.6 otomatis menggunakannya meski variabel ini dihapus.
DATA_DIR=/data
BACKUP_DIR=/data/backups
MAX_BACKUPS=30

# Kompresi v10.6 — 1080p H.265 aman untuk Railway/VPS
TELEGRAM_TARGET_GB=1.45
TELEGRAM_AUDIO_KBPS=128
TELEGRAM_VIDEO_CODEC=libx265
TELEGRAM_X265_PRESET=veryfast
TELEGRAM_X265_THREADS=2
TELEGRAM_X265_FRAME_THREADS=1
TELEGRAM_X265_WPP=0
TELEGRAM_FALLBACK_H264=1

# Cache hasil scan Bot API
SCAN_STORE_PATH=/data/telegram-scan-results.json

# Smart Watermark v2 diatur dari panel: mode statis/bergerak, ukuran, opacity, dan kecepatan.
