BOT_TOKEN=123456789:YOUR_TELEGRAM_BOT_TOKEN
CHANNEL_ID=-1001234567890
SECRET_KEY=ganti-dengan-kunci-panel-yang-panjang
TMDB_API_KEY=your_tmdb_api_key

# Jika Local Bot API berada dalam project Railway yang sama:
# TELEGRAM_API_BASE=http://telegram-bot-api.railway.internal:8081
# Jika Local Bot API berada di project Railway terpisah, gunakan Public Domain:
TELEGRAM_API_BASE=https://telegram-bot-api-production-333a.up.railway.app

TMDB_LANGUAGE=id-ID
MAX_QUEUE=20
FFMPEG_PRESET=veryfast
FFMPEG_CRF=23
DEFAULT_THREAD_ID=0
TOPIC_OPTIONS=General:0
TOPIC_STORE_PATH=/data/telegram-topics.json
SERIES_STORE_PATH=/data/telegram-series.json
EPISODE_BUTTONS_PER_ROW=5

DATA_DIR=/data
BACKUP_DIR=/data/backups
MAX_BACKUPS=30
SCAN_STORE_PATH=/data/telegram-scan-results.json

# v10.6.1 Turbo — H.265 lebih cepat
TELEGRAM_TARGET_GB=1.45
TELEGRAM_AUDIO_KBPS=128
TELEGRAM_VIDEO_CODEC=libx265
TELEGRAM_X265_PRESET=superfast
# 0 = otomatis mengikuti CPU Railway. Bisa diisi 2 atau 4 secara manual.
TELEGRAM_X265_THREADS=0
# 0 = otomatis, maksimal 2 secara default.
TELEGRAM_X265_FRAME_THREADS=0
TELEGRAM_X265_WPP=1
TELEGRAM_X265_TURBO=1
TELEGRAM_FALLBACK_H264=1

# CineDrive v11 Cluster
SUPABASE_URL=https://PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ISI_SERVICE_ROLE_KEY
CLUSTER_NAMESPACE=cinemaxx1-production
CLUSTER_WORKER_ID=railway-1

# CineDrive v11.2 Multi-Bot
# Pilihan A — satu bot per Railway: isi BOT_TOKEN berbeda pada tiap service.
# Pilihan B — beberapa bot dalam satu service: pisahkan token dengan koma.
# BOT_TOKENS=TOKEN_BOT_1,TOKEN_BOT_2,TOKEN_BOT_3
# BOT_TOKEN_INDEX=1

# CineDrive v11.3 Global Sync
# WAJIB sama pada semua Railway:
GLOBAL_SYNC_ENABLED=1
GLOBAL_SYNC_BOOTSTRAP_LOCAL=1
GLOBAL_SYNC_INTERVAL=15
# CLUSTER_NAMESPACE harus identik pada seluruh service.

# v11.4 Global Database
GLOBAL_DATABASE_PUBLISH_LOCAL=1
GLOBAL_DATABASE_REFRESH_SECONDS=10
# Setelah kedua Railway sudah menampilkan fingerprint sama, boleh diubah ke 0.
GLOBAL_SYNC_BOOTSTRAP_LOCAL=1

# CineDrive v11.5 Enterprise Cluster
ENTERPRISE_CLUSTER_ENABLED=1
ENTERPRISE_LOCK_TTL_SECONDS=21600
ENTERPRISE_JOB_RETENTION_SECONDS=86400

# CineDrive v12 Enterprise Scheduler
SCHEDULER_ENABLED=1
SCHEDULER_POLL_SECONDS=5
SCHEDULER_MAX_JOBS_PER_WORKER=1
SCHEDULER_CLAIM_TTL_SECONDS=21600

# CineDrive v12.1 Scheduler Status Dashboard
STATUS_DASHBOARD_REFRESH_SECONDS=3

# v12.3: Supabase canonical only after migration
GLOBAL_SYNC_BOOTSTRAP_LOCAL=0
GLOBAL_DATABASE_PUBLISH_LOCAL=0
GLOBAL_DATABASE_REFRESH_SECONDS=5

# CineDrive v13 Enterprise
# Bot khusus yang selalu membuat/menghapus katalog serial. Sangat disarankan
# menggunakan token yang sama pada seluruh Railway.
# Jika kosong, katalog memakai bot aktif pada worker tersebut.
CATALOG_BOT_TOKEN=

# Alihkan otomatis job QUEUED jika worker tujuan tidak lagi aktif.
# Job yang sudah PROCESSING/UPLOADING tidak dialihkan agar tidak duplikat.
V13_QUEUE_FAILOVER_ENABLED=1
V13_QUEUE_FAILOVER_SECONDS=120
V13_MAX_RECENT_JOBS=50

# v13.1 Global Unassigned Queue
SCHEDULER_ENABLED=1
SCHEDULER_POLL_SECONDS=5
SCHEDULER_MAX_JOBS_PER_WORKER=1
SCHEDULER_CLAIM_TTL_SECONDS=21600
V13_QUEUE_FAILOVER_ENABLED=1
V13_QUEUE_FAILOVER_SECONDS=120

# v13.3 Global Assets + Sequential Series Scheduler
# Logo Google Drive dipilih dari panel; tidak memerlukan variabel tambahan.
# Pastikan file logo dibagikan: Anyone with the link -> Viewer.

# Jalankan episode serial secara berurutan pada semua Railway
SERIES_SEQUENTIAL_SCHEDULER=1

# CineDrive v14 Enterprise Smart Pipeline Scheduler
SMART_PIPELINE_SCHEDULER=1
SMART_PIPELINE_POLL_SECONDS=5
SMART_PIPELINE_WAIT_TIMEOUT_SECONDS=86400
# Tetap 1 agar setiap Railway menyiapkan satu job pada satu waktu.
SCHEDULER_MAX_JOBS_PER_WORKER=1
# CineDrive v15 Central Configuration
# Non-secret defaults are in config.json. Optional remote override:
CONFIG_FILE=config.json
# CONFIG_URL=https://raw.githubusercontent.com/USER/REPO/main/config.json
V15_AUTO_RECOVERY_ENABLED=1
V15_AUTO_CLEANUP_ENABLED=1
V15_UPLOAD_RETRIES=3
V15_SUCCESS_RETENTION_SECONDS=604800
V15_ERROR_RETENTION_SECONDS=86400

# Fallback jika Local Bot API tidak dapat dijangkau
TELEGRAM_API_FALLBACK_BASE="https://api.telegram.org"

# Worker dianggap offline jika heartbeat tidak diperbarui selama nilai ini
WORKER_OFFLINE_SECONDS="90"
